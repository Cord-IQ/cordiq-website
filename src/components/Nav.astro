---
const DISCORD_URL = 'https://discord.gg/W2QqfrgAFC';

/* On the homepage these are in-page anchors; elsewhere they need to
   point back to "/" first, otherwise "#services" resolves nowhere. */
const isHome = Astro.url.pathname === '/';
const base = isHome ? '' : '/';

const links = [
  { href: `${base}#services`, label: 'Services' },
  { href: `${base}#pricing`, label: 'Pricing' },
  { href: `${base}#why`, label: 'Why CordIQ' },
  { href: `${base}#process`, label: 'Process' },
  { href: `${base}#work`, label: 'Our Work' },
  { href: `${base}#faq`, label: 'FAQ' },
];
---

<header
  id="site-nav"
  class="fixed inset-x-0 top-0 z-50 transition-[background-color,border-color,backdrop-filter] duration-300"
>
  <nav
    class="mx-auto flex max-w-6xl items-center justify-between px-5 py-4 md:px-8"
    aria-label="Main navigation"
  >
    <a href="/" class="inline-flex items-center" aria-label="CordIQ home">
      <img
        src="/brand/wordmark-light.webp"
        alt="CordIQ"
        class="h-9 w-auto"
        width="158"
        height="36"
      />
    </a>

    <ul class="hidden items-center gap-8 md:flex">
      {links.map((l) => (
        <li>
          <a
            href={l.href}
            class="text-sm text-mist-300 transition-colors hover:text-white"
          >
            {l.label}
          </a>
        </li>
      ))}
    </ul>

    <div class="flex items-center gap-3">
      <a
        href={DISCORD_URL}
        target="_blank"
        rel="noopener"
        class="btn-primary hidden rounded-full px-5 py-2.5 text-sm font-semibold text-white sm:inline-flex"
      >
        Join our Discord
      </a>
      <button
        id="menu-toggle"
        class="btn-ghost inline-flex h-10 w-10 items-center justify-center rounded-full md:hidden"
        aria-label="Toggle menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" d="M4 7h16M4 12h16M4 17h16" />
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="hidden border-t border-white/8 bg-ink-900/95 backdrop-blur-xl md:hidden"
  >
    <ul class="space-y-1 px-5 py-4">
      {links.map((l) => (
        <li>
          <a
            href={l.href}
            class="block rounded-lg px-3 py-2.5 text-mist-300 transition-colors hover:bg-white/5 hover:text-white"
          >
            {l.label}
          </a>
        </li>
      ))}
      <li class="pt-2">
        <a
          href={DISCORD_URL}
          target="_blank"
          rel="noopener"
          class="btn-primary block rounded-full px-5 py-3 text-center font-semibold text-white"
        >
          Join our Discord
        </a>
      </li>
    </ul>
  </div>
</header>

<script>
  const nav = document.getElementById('site-nav')!;
  const toggle = document.getElementById('menu-toggle')!;
  const menu = document.getElementById('mobile-menu')!;

  // Glass background once scrolled
  const onScroll = () => {
    if (window.scrollY > 24) {
      nav.classList.add('bg-ink-950/80', 'backdrop-blur-xl', 'border-b', 'border-white/8');
    } else {
      nav.classList.remove('bg-ink-950/80', 'backdrop-blur-xl', 'border-b', 'border-white/8');
    }
  };
  onScroll();
  window.addEventListener('scroll', onScroll, { passive: true });

  toggle.addEventListener('click', () => {
    const open = menu.classList.toggle('hidden') === false;
    toggle.setAttribute('aria-expanded', String(open));
  });
  // Close menu when a link is tapped
  menu.querySelectorAll('a').forEach((a) =>
    a.addEventListener('click', () => {
      menu.classList.add('hidden');
      toggle.setAttribute('aria-expanded', 'false');
    })
  );
</script>

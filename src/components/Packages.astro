---
import { packages, carePlan } from '../data/packages';

const DISCORD_URL = 'https://discord.gg/W2QqfrgAFC';

interface Props {
  /* Homepage shows a link through to /pricing; the pricing page does not. */
  showCompareLink?: boolean;
  heading?: string;
  intro?: string;
}

const {
  showCompareLink = true,
  heading = 'Pick the level your community needs',
  intro = 'Packages are priced by what your bot has to do, not by category. Every project gets an exact quote in a free consultation - no surprises.',
} = Astro.props;
---

<section id="pricing" class="relative scroll-mt-24 overflow-hidden py-24 md:py-32">
  <div
    class="absolute top-0 left-1/2 h-72 w-[560px] -translate-x-1/2 rounded-full bg-brand-700/15 blur-[130px]"
    aria-hidden="true"
  >
  </div>

  <div class="relative mx-auto max-w-6xl px-5 md:px-8">
    <div class="mx-auto max-w-2xl text-center">
      <span class="reveal inline-block rounded-full border border-brand-500/30 bg-brand-500/10 px-4 py-1.5 text-sm font-medium text-brand-300">
        Packages
      </span>
      <h2 class="reveal font-display mt-5 text-3xl font-bold tracking-tight text-balance md:text-5xl" style="--reveal-delay: 80ms">
        {heading}
      </h2>
      <p class="reveal mt-4 text-lg text-mist-300" style="--reveal-delay: 160ms">
        {intro}
      </p>
    </div>

    <div class="mt-14 grid items-start gap-5 lg:grid-cols-3">
      {packages.map((p, i) => (
        <article
          class:list={[
            'glass-card reveal relative flex flex-col rounded-2xl p-7',
            p.featured && 'ring-1 ring-brand-500/50 lg:-mt-4 lg:pb-9',
          ]}
          style={`--reveal-delay: ${i * 90}ms`}
        >
          {p.featured && (
            <span class="absolute -top-3 left-1/2 -translate-x-1/2 rounded-full bg-brand-500 px-3.5 py-1 text-xs font-semibold whitespace-nowrap text-white">
              Most popular
            </span>
          )}

          <h3 class="font-display text-xl font-semibold text-white">{p.name}</h3>
          <p class="mt-1.5 text-sm text-mist-500">{p.bestFor}</p>

          <p class="mt-6 flex items-baseline gap-1.5">
            <span class="text-sm text-mist-500">from</span>
            <span class="font-display text-4xl font-bold text-white tabular-nums">${p.price}</span>
          </p>
          <p class="mt-2 text-sm text-brand-300">{p.tagline}</p>

          <ul class="mt-6 flex-1 space-y-3">
            {p.features.map((f) => (
              <li class="flex gap-2.5 text-sm leading-relaxed text-mist-300">
                <svg class="mt-0.5 h-4 w-4 shrink-0 text-accent-400" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                </svg>
                <span class="min-w-0">{f}</span>
              </li>
            ))}
          </ul>

          <dl class="mt-6 grid grid-cols-2 gap-3 border-t border-white/8 pt-5 text-sm">
            <div>
              <dt class="text-mist-500">Delivery</dt>
              <dd class="mt-0.5 font-medium text-white">{p.delivery}</dd>
            </div>
            <div>
              <dt class="text-mist-500">Revisions</dt>
              <dd class="mt-0.5 font-medium text-white">{p.revisions}</dd>
            </div>
          </dl>

          <a
            href={DISCORD_URL}
            target="_blank"
            rel="noopener"
            class:list={[
              'mt-6 inline-flex items-center justify-center rounded-full px-6 py-3 text-sm font-semibold',
              p.featured ? 'btn-primary text-white' : 'btn-ghost text-mist-100',
            ]}
          >
            Get a quote for {p.name}
          </a>
        </article>
      ))}
    </div>

    <!-- Care plan add-on -->
    <div class="glass-card reveal mt-6 flex flex-col gap-6 rounded-2xl p-7 md:flex-row md:items-center md:justify-between">
      <div class="max-w-xl">
        <div class="flex flex-wrap items-baseline gap-3">
          <h3 class="font-display text-lg font-semibold text-white">{carePlan.name}</h3>
          <span class="rounded-full border border-accent-400/30 bg-accent-400/10 px-3 py-0.5 text-xs font-medium text-accent-300">
            Optional add-on
          </span>
        </div>
        <p class="mt-2 text-sm leading-relaxed text-mist-300">{carePlan.desc}</p>
        <ul class="mt-3 flex flex-wrap gap-x-5 gap-y-1.5">
          {carePlan.features.map((f) => (
            <li class="text-sm text-mist-500">{f}</li>
          ))}
        </ul>
      </div>
      <p class="flex shrink-0 items-baseline gap-1.5">
        <span class="text-sm text-mist-500">from</span>
        <span class="font-display text-3xl font-bold text-white tabular-nums">${carePlan.price}</span>
        <span class="text-sm text-mist-500">{carePlan.unit}</span>
      </p>
    </div>

    <p class="reveal mt-8 text-center text-mist-300">
      {showCompareLink ? (
        <a href="/pricing" class="font-semibold text-brand-300 underline-offset-4 hover:underline">
          Compare every feature side by side →
        </a>
      ) : (
        <>
          Not sure which fits?{' '}
          <a href={DISCORD_URL} target="_blank" rel="noopener" class="font-semibold text-brand-300 underline-offset-4 hover:underline">
            Ask us on Discord - it&rsquo;s free →
          </a>
        </>
      )}
    </p>
  </div>
</section>

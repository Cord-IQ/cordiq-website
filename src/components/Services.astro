---

<section id="services" class="relative scroll-mt-24 overflow-hidden py-24 md:py-32">
  <div
    class="absolute top-0 left-1/2 h-72 w-[560px] -translate-x-1/2 rounded-full bg-brand-700/15 blur-[130px]"
    aria-hidden="true"
  >
  </div>

  <div class="relative mx-auto max-w-6xl px-5 md:px-8">
    <div class="mx-auto max-w-2xl text-center">
      <span class="reveal inline-block rounded-full border border-brand-500/30 bg-brand-500/10 px-4 py-1.5 text-sm font-medium text-brand-300">
        What we build
      </span>
      <h2 class="reveal font-display mt-5 text-3xl font-bold tracking-tight text-balance md:text-5xl" style="--reveal-delay: 80ms">
        Any bot you can imagine. <span class="text-brand-400">Built right.</span>
      </h2>
      <p class="reveal mt-4 text-lg text-mist-300" style="--reveal-delay: 160ms">
        Every project is coded from scratch for your exact needs - and every quote is
        tailored in a free consultation on our Discord.
      </p>
    </div>

    <div class="mt-14 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {services.map((s, i) => (
        <article
          class:list={[
            'glass-card reveal group relative flex flex-col rounded-2xl p-7',
            s.featured && 'ring-1 ring-brand-500/40',
          ]}
          style={`--reveal-delay: ${(i % 3) * 90}ms`}
        >
          {s.featured && (
            <span class="absolute -top-3 right-6 rounded-full bg-gradient-to-r from-brand-500 to-accent-500 px-3 py-1 text-xs font-semibold text-white">
              Most popular
            </span>
          )}
          <div class="mb-5 inline-flex h-12 w-12 items-center justify-center rounded-xl border border-brand-500/25 bg-brand-500/10 text-brand-300 transition-colors group-hover:text-accent-300">
            <svg class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d={s.icon} />
            </svg>
          </div>
          <h3 class="font-display text-lg font-semibold text-white">{s.title}</h3>
          <p class="mt-2.5 flex-1 text-sm leading-relaxed text-mist-300">{s.desc}</p>
          <p class="mt-5 font-mono text-sm font-medium text-accent-400">{s.price}</p>
        </article>
      ))}
    </div>

    <p class="reveal mt-10 text-center text-mist-300">
      Something else in mind?{' '}
      <a href={DISCORD_URL} target="_blank" rel="noopener" class="font-semibold text-brand-300 underline-offset-4 hover:underline">
        Tell us about it →
      </a>
    </p>
  </div>
</section>

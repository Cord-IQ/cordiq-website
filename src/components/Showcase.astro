---
/* ============================================================
   PLACEHOLDER DATA - replace with your real projects.
   Swap `tag`, `title`, `desc`, `metrics` per project and drop
   real screenshots into /public/work/ then set `img`.
   ============================================================ */
const projects = [
  {
    tag: 'Ticket & Support',
    title: 'Project placeholder one',
    desc: 'Short description of the bot: what community it serves, what it automates, and the result it delivered.',
    metrics: ['00k+ members served', '00k tickets handled'],
    img: '/visuals/showcase-tickets.webp',
  },
  {
    tag: 'AI-Powered',
    title: 'Project placeholder two',
    desc: 'Short description of the bot: what community it serves, what it automates, and the result it delivered.',
    metrics: ['00% faster responses', '24/7 automation'],
    img: '/visuals/showcase-ai.webp',
  },
  {
    tag: 'Economy & Engagement',
    title: 'Project placeholder three',
    desc: 'Short description of the bot: what community it serves, what it automates, and the result it delivered.',
    metrics: ['00% activity boost', '00k daily commands'],
    img: '/visuals/showcase-economy.webp',
  },
];
---

<section id="work" class="relative scroll-mt-24 overflow-hidden bg-ink-900/50 py-24 md:py-32">
  <div
    class="absolute -left-32 top-1/3 h-96 w-96 rounded-full bg-brand-600/12 blur-[130px]"
    aria-hidden="true"
  >
  </div>

  <div class="relative mx-auto max-w-6xl px-5 md:px-8">
    <div class="mx-auto max-w-2xl text-center">
      <span class="reveal inline-block rounded-full border border-accent-400/30 bg-accent-400/10 px-4 py-1.5 text-sm font-medium text-accent-300">
        Our work
      </span>
      <h2 class="reveal font-display mt-5 text-3xl font-bold tracking-tight text-balance md:text-5xl" style="--reveal-delay: 80ms">
        Bots that <span class="text-gradient">communities run on</span>
      </h2>
    </div>

    <div class="mt-14 grid gap-5 md:grid-cols-3">
      {projects.map((p, i) => (
        <article class="glass-card reveal group overflow-hidden rounded-2xl" style={`--reveal-delay: ${i * 100}ms`}>
          <!-- Visual header: replace with real screenshot when available -->
          <div class="relative flex h-44 items-center justify-center overflow-hidden border-b border-white/6 bg-gradient-to-br from-brand-800/40 via-ink-800 to-ink-900">
            {p.img ? (
              <img
                src={p.img}
                alt={p.title}
                class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                width="800"
                height="533"
                loading="lazy"
              />
            ) : (
              <img
                src="/brand/Primary_no_bg_icon.png"
                alt=""
                class="animate-float h-16 w-16 opacity-40 transition-opacity group-hover:opacity-70"
                width="64"
                height="64"
                loading="lazy"
              />
            )}
            <span class="absolute top-4 left-4 rounded-full border border-white/10 bg-ink-950/70 px-3 py-1 text-xs font-medium text-accent-300 backdrop-blur">
              {p.tag}
            </span>
          </div>
          <div class="p-6">
            <h3 class="font-display text-lg font-semibold text-white">{p.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-mist-300">{p.desc}</p>
            <ul class="mt-4 flex flex-wrap gap-2">
              {p.metrics.map((m) => (
                <li class="rounded-full bg-brand-500/10 px-3 py-1 font-mono text-xs text-brand-300">{m}</li>
              ))}
            </ul>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

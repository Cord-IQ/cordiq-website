---
/* Technologies CordIQ actually builds with — edit freely */
const tech = [
  'discord.js',
  'discord.py',
  'Node.js',
  'Python',
  'TypeScript',
  'MongoDB',
  'PostgreSQL',
  'Redis',
  'REST APIs',
  'Claude API',
  'OpenAI API',
  'Docker',
];
---

<section class="relative border-y border-white/6 bg-ink-900/60 py-10" aria-label="Technologies we work with">
  <p class="mb-6 text-center text-sm font-medium tracking-widest text-mist-500 uppercase">
    Built with battle-tested technology
  </p>
  <div
    class="relative overflow-hidden"
    style="mask-image: linear-gradient(90deg, transparent, black 12%, black 88%, transparent)"
  >
    <div class="animate-marquee flex w-max gap-4 pr-4">
      {[...tech, ...tech].map((t) => (
        <span class="rounded-full border border-white/8 bg-white/3 px-5 py-2 font-mono text-sm whitespace-nowrap text-mist-300">
          {t}
        </span>
      ))}
    </div>
  </div>
</section>

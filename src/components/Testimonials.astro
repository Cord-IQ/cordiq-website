---
/* ============================================================
   PLACEHOLDER REVIEWS — replace with real Fiverr reviews.
   Keep name/initials + server type; quote text goes in `quote`.
   ============================================================ */
const reviews = [
  {
    initials: 'AB',
    name: 'Client name',
    role: 'Gaming community · 00k members',
    quote:
      'Placeholder review — paste a real client quote here. Two or three sentences about the experience and the result works best.',
  },
  {
    initials: 'CD',
    name: 'Client name',
    role: 'E-commerce server',
    quote:
      'Placeholder review — paste a real client quote here. Two or three sentences about the experience and the result works best.',
  },
  {
    initials: 'EF',
    name: 'Client name',
    role: 'Creator community',
    quote:
      'Placeholder review — paste a real client quote here. Two or three sentences about the experience and the result works best.',
  },
];
---

<section class="relative py-24 md:py-32">
  <div class="mx-auto max-w-6xl px-5 md:px-8">
    <div class="mx-auto max-w-2xl text-center">
      <span class="reveal inline-block rounded-full border border-brand-500/30 bg-brand-500/10 px-4 py-1.5 text-sm font-medium text-brand-300">
        Testimonials
      </span>
      <h2 class="reveal font-display mt-5 text-3xl font-bold tracking-tight text-balance md:text-5xl" style="--reveal-delay: 80ms">
        Trusted by server owners <span class="text-gradient">worldwide</span>
      </h2>
    </div>

    <div class="mt-14 grid gap-5 md:grid-cols-3">
      {reviews.map((r, i) => (
        <figure class="glass-card reveal flex flex-col rounded-2xl p-7" style={`--reveal-delay: ${i * 100}ms`}>
          <div class="mb-4 flex gap-1 text-accent-400" aria-label="5 out of 5 stars">
            {Array.from({ length: 5 }).map(() => (
              <svg class="h-4.5 w-4.5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.196-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118L2.077 10.1c-.783-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" />
              </svg>
            ))}
          </div>
          <blockquote class="flex-1 text-sm leading-relaxed text-mist-300">
            “{r.quote}”
          </blockquote>
          <figcaption class="mt-6 flex items-center gap-3">
            <span class="font-display inline-flex h-10 w-10 items-center justify-center rounded-full bg-gradient-to-br from-brand-500 to-accent-500 text-sm font-bold text-white">
              {r.initials}
            </span>
            <span>
              <span class="block text-sm font-semibold text-white">{r.name}</span>
              <span class="block text-xs text-mist-500">{r.role}</span>
            </span>
          </figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>

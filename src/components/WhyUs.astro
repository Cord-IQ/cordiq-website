---
const points = [
  {
    title: 'Direct line to the developers',
    desc: 'No middlemen, no marketplace fees inflating your price. You talk straight to the two engineers writing your code.',
    icon: 'M8.625 12a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H8.25m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H12m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0h-.375M21 12c0 4.556-4.03 8.25-9 8.25a9.764 9.764 0 01-2.555-.337A5.972 5.972 0 015.41 20.97a5.969 5.969 0 01-.474-.065 4.48 4.48 0 00.978-2.025c.09-.457-.133-.901-.467-1.226C3.93 16.178 3 14.189 3 12c0-4.556 4.03-8.25 9-8.25s9 3.694 9 8.25z',
  },
  {
    title: '4+ years, hundreds of servers',
    desc: 'We spent 4 years mastering Discord bots as a top freelance duo. Now that experience works for you - without the platform limits.',
    icon: 'M15.362 5.214A8.252 8.252 0 0112 21 8.25 8.25 0 016.038 7.048 8.287 8.287 0 009 9.6a8.983 8.983 0 013.361-6.867 8.21 8.21 0 003 2.48z',
  },
  {
    title: 'Truly custom, never templates',
    desc: 'Off-the-shelf bots make your server feel like everyone else’s. We build from a blank file: your features, your branding, your rules.',
    icon: 'M9.53 16.122a3 3 0 00-5.78 1.128 2.25 2.25 0 01-2.4 2.245 4.5 4.5 0 008.4-2.245c0-.399-.078-.78-.22-1.128zm0 0a15.998 15.998 0 003.388-1.62m-5.043-.025a15.994 15.994 0 011.622-3.395m3.42 3.42a15.995 15.995 0 004.764-4.648l3.876-5.814a1.151 1.151 0 00-1.597-1.597L14.146 6.32a15.996 15.996 0 00-4.649 4.763m3.42 3.42a6.776 6.776 0 00-3.42-3.42',
  },
  {
    title: 'Long-term partnership',
    desc: 'Delivery isn’t goodbye. We host, monitor and evolve your bot as your community grows - with support you can actually reach.',
    icon: 'M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z',
  },
];
---

<section id="why" class="relative scroll-mt-24 overflow-hidden bg-ink-900/50 py-24 md:py-32">
  <div
    class="absolute -right-32 top-1/4 h-96 w-96 rounded-full bg-accent-500/8 blur-[130px]"
    aria-hidden="true"
  >
  </div>

  <div class="relative mx-auto max-w-6xl px-5 md:px-8">
    <div class="grid items-center gap-14 lg:grid-cols-2">
      <div>
        <span class="reveal inline-block rounded-full border border-accent-400/30 bg-accent-400/10 px-4 py-1.5 text-sm font-medium text-accent-300">
          Why CordIQ
        </span>
        <h2 class="reveal font-display mt-5 text-3xl font-bold tracking-tight text-balance md:text-5xl" style="--reveal-delay: 80ms">
          Freelancer prices.<br />
          <span class="text-gradient">Agency quality.</span>
        </h2>
        <p class="reveal mt-5 text-lg leading-relaxed text-mist-300" style="--reveal-delay: 160ms">
          CordIQ was born after 4 years of delivering custom Discord bots on
          freelance marketplaces. We went independent for one reason: to serve
          clients better - faster communication, fairer pricing and real
          long-term support, without a platform in the way.
        </p>

        <div class="reveal mt-8 flex items-center gap-4 rounded-2xl border border-white/8 bg-white/3 p-5" style="--reveal-delay: 240ms">
          <img src="/brand/Primary_icon.png" alt="" class="h-12 w-12 rounded-xl" width="48" height="48" />
          <p class="text-sm leading-relaxed text-mist-300">
            <span class="font-semibold text-white">Two partners. One standard.</span><br />
            Every bot is planned, coded and reviewed by both of us before it ships.
          </p>
        </div>
      </div>

      <div class="grid gap-5 sm:grid-cols-2">
        {points.map((p, i) => (
          <div class="glass-card reveal rounded-2xl p-6" style={`--reveal-delay: ${i * 90}ms`}>
            <div class="mb-4 inline-flex h-11 w-11 items-center justify-center rounded-xl border border-accent-400/25 bg-accent-400/10 text-accent-300">
              <svg class="h-5.5 w-5.5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d={p.icon} />
              </svg>
            </div>
            <h3 class="font-display font-semibold text-white">{p.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-mist-300">{p.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

---
import Layout from './Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  updated: string;
}

const { title, description, updated } = Astro.props;
---

<Layout title={`${title} — CordIQ`} description={description}>
  <Nav />
  <main id="main" class="mx-auto max-w-3xl px-5 pt-36 pb-24 md:px-8">
    <h1 class="font-display text-4xl font-bold tracking-tight">{title}</h1>
    <p class="mt-3 text-sm text-mist-500">Last updated: {updated}</p>
    <div
      class="prose-legal mt-10 space-y-8 text-[15px] leading-relaxed text-mist-300 [&_h2]:font-display [&_h2]:text-xl [&_h2]:font-semibold [&_h2]:text-white [&_p]:mt-3 [&_ul]:mt-3 [&_ul]:list-disc [&_ul]:space-y-1.5 [&_ul]:pl-6"
    >
      <slot />
    </div>
  </main>
  <Footer />
</Layout>
